# Proxmox API Configuration
PROXMOX_URL=https://<your-proxmox-ip>:8006/api2/json
PROXMOX_TOKEN_NAME=User@pam!TokenName
PROXMOX_TOKEN_VALUE=your-token-secret-uuid
PROXMOX_VERIFY_SSL=false

# Security Settings
# Set to true to enable destructive actions like delete_instance
PROXMOX_ALLOW_DANGER=false
